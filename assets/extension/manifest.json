{
  "manifest_version": 3,
  "name": "DayLens Tracker",
  "version": "1.0.0",
  "description": "Tracks websites you visit and sends data to your DayLens desktop app.",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "ws://127.0.0.1:43821/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "DayLens Tracker",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png"
  }
}
